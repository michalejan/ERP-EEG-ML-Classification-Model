    {
      "cell_type": "code",
      "source": [
        "# baseline correction - we want to start from 0.00 not -100ish ms to see the accurate signal\n",
        "epochs.apply_baseline(baseline=(None, 0))\n",
        "# averaging out the noise to make the ERP stand out\n",
        "evoked_control = epochs['Control'].average()\n",
        "evoked_violation = epochs['Violation'].average()\n",
        "\n",
        "# we plot the \"BUTTERFLY PLOT\" for the violation codnition\n",
        "evoked_violation.plot(spatial_colors=True, gfp=True, window_title=\"Butterfly Plot: Syntax Violation\")\n",
        "\n",
        "# Comparing the \"Condition\" and \"Violation\" at the Pz electrode\n",
        "mne.viz.plot_compare_evokeds(\n",
        "    dict(Control=evoked_control, Violation=evoked_violation),\n",
        "    picks='Pz',\n",
        "    colors=dict(Control='blue', Violation='red'),\n",
        "    title='ERP at Pz: Control vs. Syntax Violation',\n",
        "    invert_y=False # positive voltage above the x axis\n",
