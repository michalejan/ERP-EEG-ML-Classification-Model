      "source": [
        "# first we identify the integer codes of the ctrl and viol labels\n",
        "control_codes = [code for name, code in epochs.event_id.items() if '(110)' in name or '(115)' in name]\n",
        "violation_codes = [code for name, code in epochs.event_id.items() if '(220)' in name or '(225)' in name]\n",
        "\n",
        "print(f\"old Control integers: {control_codes}\")\n",
        "print(f\"old Violation integers: {violation_codes}\")\n",
        "\n",
        "# rewriting the labels into ctrl and viol\n",
        "for i in range(len(epochs.events)):\n",
        "    if epochs.events[i, 2] in control_codes:\n",
        "        epochs.events[i, 2] = 1\n",
        "    elif epochs.events[i, 2] in violation_codes:\n",
        "        epochs.events[i, 2] = 2\n",
        "\n",
        "# a new dict\n",
        "epochs.event_id = {'Control': 1, 'Violation': 2}\n",
        "\n",
        "# let's verify\n",
        "print(\"Cleaned Event IDs:\", epochs.event_id)"
